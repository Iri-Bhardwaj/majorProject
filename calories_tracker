# ─── MongoDB ──────────────────────────────────────────────────────────────────
def get_db():
    try:
        client = MongoClient(MONGO_URI, serverSelectionTimeoutMS=3000)
        client.server_info()
        return client["calories_tracker"]
    except Exception:
        return None

# ─── CSV fallback ─────────────────────────────────────────────────────────────
def load_csv():
    if os.path.exists(CSV_FILE):
        return pd.read_csv(CSV_FILE)
    return pd.DataFrame(columns=["date","meal_type","food","calories","quantity"])

def save_csv(df):
    df.to_csv(CSV_FILE, index=False)

# ─── Anthropic Vision API ─────────────────────────────────────────────────────
def analyse_food_image(image_path: str) -> dict:
    """
    Sends the image to Claude claude-sonnet-4-20250514 vision and returns
    {"food": str, "calories": int, "explanation": str}
    """
    with open(image_path, "rb") as f:
        image_data = base64.standard_b64encode(f.read()).decode("utf-8")

    ext = os.path.splitext(image_path)[1].lower()
    media_map = {".jpg": "image/jpeg", ".jpeg": "image/jpeg",
                 ".png": "image/png",  ".webp": "image/webp"}
    media_type = media_map.get(ext, "image/jpeg")

    payload = json.dumps({
        "model": "claude-sonnet-4-20250514",
        "max_tokens": 300,
        "messages": [{
            "role": "user",
            "content": [
                {"type": "image",
                 "source": {"type": "base64",
                            "media_type": media_type,
                            "data": image_data}},
                {"type": "text",
                 "text": (
                    "You are a nutrition expert. Look at this food image and respond ONLY "
                    "with a JSON object — no extra text, no markdown. Format:\n"
                    '{"food": "<name of food>", "calories": <integer kcal estimate for one serving>, '
                    '"explanation": "<one short sentence explaining the estimate>"}'
                 )}
            ]
        }]
    }).encode("utf-8")

    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=payload,
        headers={
            "Content-Type":      "application/json",
            "x-api-key":         ANTHROPIC_KEY,
            "anthropic-version": "2023-06-01"
        },
        method="POST"
    )
    with urllib.request.urlopen(req, timeout=20) as resp:
        result = json.loads(resp.read().decode("utf-8"))

    raw = result["content"][0]["text"].strip()
    # Strip markdown fences if model wraps them
    raw = raw.replace("```json", "").replace("```", "").strip()
    return json.loads(raw)

# ─── Main App ─────────────────────────────────────────────────────────────────
