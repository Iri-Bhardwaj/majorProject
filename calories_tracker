        self.update_week_chart()

    def _build_log_tab(self, parent):
        C = self.C
        f = tk.Frame(parent, bg=C["BG"])
        f.pack(fill="both", expand=True, padx=8, pady=8)

        cols = ("Meal","Food","Qty","Calories","Source")
        self.tree = ttk.Treeview(f, columns=cols, show="headings", height=18)
        widths = [100,190,50,90,70]
        for col,w in zip(cols,widths):
            self.tree.heading(col, text=col)
            self.tree.column(col, width=w, anchor="center")

        sc = ttk.Scrollbar(f, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscrollcommand=sc.set)
        self.tree.pack(side="left", fill="both", expand=True)
        sc.pack(side="right", fill="y")

        btn = tk.Frame(parent, bg=C["BG"])
        btn.pack(fill="x", padx=8, pady=4)
        tk.Button(btn, text="Delete Selected", command=self.delete_entry,
                  font=("Courier New",10), bg=C["CARD"], fg=C["RED"],
                  relief="flat", cursor="hand2", pady=6).pack(side="left", padx=(0,8))
        tk.Button(btn, text="Refresh Charts", command=self.update_charts,
                  font=("Courier New",10), bg=C["CARD"], fg=C["ACCENT"],
                  relief="flat", cursor="hand2", pady=6).pack(side="left")

    # ── Image helpers ─────────────────────────────────────────────────────────
    def _pick_image(self):
        path = filedialog.askopenfilename(
            title="Select food image",
            filetypes=[("Images","*.jpg *.jpeg *.png *.webp")]
        )
        if not path:
            return
        self.selected_image_path = path
        fname = os.path.basename(path)
        self.img_preview.config(text=f"Selected:\n{fname}", fg=self.C["TEXT"])
        self.img_result_lbl.config(text="")
        self.img_cal_var.set("")
        self.img_food_name.set("")

    def _analyse_image(self):
        if not self.selected_image_path:
            messagebox.showwarning("No Image", "Please choose a food photo first.")
            return
        if ANTHROPIC_KEY == "YOUR_ANTHROPIC_API_KEY":
            messagebox.showerror("API Key Missing",
                "Add your Anthropic API key to the ANTHROPIC_KEY variable in the code.")
            return

        self.analyse_btn.config(text="Analysing...", state="disabled")
        self.root.update()

        try:
            result = analyse_food_image(self.selected_image_path)
            food = result.get("food","Unknown")
            cal  = int(result.get("calories", 0))
            expl = result.get("explanation","")

            self.img_food_name.set(food)
            self.img_cal_var.set(str(cal))
            self.img_result_lbl.config(
                text=f"Food: {food}\nEst. Calories: {cal} kcal\n\n{expl}",
                fg=self.C["GREEN"]
            )
        except Exception as e:
            self.img_result_lbl.config(text=f"Error: {e}", fg=self.C["RED"])
        finally:
            self.analyse_btn.config(text="Analyse Image", state="normal")

    def _add_image_entry(self):
        food = self.img_food_name.get().strip()
        cal_str = self.img_cal_var.get().strip()
        if not food or not cal_str:
            messagebox.showwarning("Analyse First",
                "Please select an image and click Analyse Image first.")
            return
        try:
            cal = float(cal_str)
        except ValueError:
            messagebox.showerror("Error","Invalid calorie value.")
            return

        entry = {
            "date": self.today,
            "meal_type": self.img_meal_var.get(),
            "food": food,
            "calories": cal,
            "quantity": 1.0,
            "source": "image"
        }
        self._save_entry(entry)
        self.img_result_lbl.config(text="Added!", fg=self.C["GREEN"])

    # ── CRUD helpers ──────────────────────────────────────────────────────────
    def _save_entry(self, entry):
        if self.using_mongo:
            self.db["meals"].insert_one({k:v for k,v in entry.items()})
        else:
            row = pd.DataFrame([entry])
            self.df = pd.concat([self.df, row], ignore_index=True)
            save_csv(self.df)
        self.refresh_today_log()

    def add_entry(self):
        food = self.food_var.get().strip()
        try:
            cal = float(self.cal_var.get())
            qty = float(self.qty_var.get())
        except ValueError:
            messagebox.showerror("Error","Enter valid numbers.")
            return
        self._save_entry({
            "date": self.today, "meal_type": self.meal_type_var.get(),
            "food": food, "calories": round(cal*qty,1),
            "quantity": qty, "source": "manual"
        })

    def delete_entry(self):
        sel = self.tree.selection()
        if not sel:
            messagebox.showwarning("Select Row","Please select a row to delete.")
            return
        vals = self.tree.item(sel[0])["values"]
        food_name = vals[1]
        if self.using_mongo:
            self.db["meals"].delete_one({"date":self.today,"food":food_name})
        else:
            self.df = load_csv()
            idx = self.df[(self.df["date"]==self.today)&(self.df["food"]==food_name)].index
            if len(idx):
                self.df = self.df.drop(idx[0])
                save_csv(self.df)
        self.refresh_today_log()

    # ── Data getters ──────────────────────────────────────────────────────────
    def _get_today(self):
        if self.using_mongo:
            rows = list(self.db["meals"].find({"date":self.today},{"_id":0}))
            return pd.DataFrame(rows) if rows else pd.DataFrame(
                columns=["date","meal_type","food","calories","quantity","source"])
        self.df = load_csv()
        return self.df[self.df["date"]==self.today]

    def _get_all(self):
        if self.using_mongo:
            rows = list(self.db["meals"].find({},{"_id":0}))
            return pd.DataFrame(rows) if rows else pd.DataFrame(
                columns=["date","meal_type","food","calories","quantity","source"])
        return load_csv()

    # ── UI updaters ───────────────────────────────────────────────────────────
    def refresh_today_log(self):
        for r in self.tree.get_children():
            self.tree.delete(r)
        df = self._get_today()
        if not df.empty:
            for _,r in df.iterrows():
                src = r.get("source","manual")
                self.tree.insert("","end", values=(
                    r["meal_type"], r["food"],
                    f"x{r['quantity']}", f"{r['calories']} kcal",
                    "IMG" if src=="image" else "-"
                ))
        total = df["calories"].sum() if not df.empty else 0
        rem   = self.goal - total
        self.total_lbl.config(text=f"Total: {total:.0f} kcal")
        self.remain_lbl.config(text=f"Remaining: {rem:.0f} kcal",
                               fg=self.C["RED"] if rem<0 else self.C["GREEN"])
        self.count_lbl.config(text=f"Entries: {len(df)}")

    def _set_goal(self):
        self.goal = self.goal_var.get()
        messagebox.showinfo("Goal Set", f"Daily goal set to {self.goal} kcal!")
        self.refresh_today_log()

    def _on_food_select(self, _=None):
        self.cal_var.set(str(FOOD_DB.get(self.food_var.get(), 0)))

    def update_charts(self):
        for w in self.chart_frame.winfo_children(): w.destroy()
        df = self._get_today()
        fig, (ax1,ax2) = plt.subplots(1,2, figsize=(8,3.5), facecolor="#1a1a1a")
        COLORS = ["#f97316","#22c55e","#3b82f6","#a855f7","#ef4444","#eab308"]

        ax1.set_facecolor("#1a1a1a")
        if not df.empty:
            grp = df.groupby("meal_type")["calories"].sum()
            ax1.pie(grp.values, labels=grp.index, autopct="%1.0f%%",
                    colors=COLORS[:len(grp)],
                    textprops={"color":"white","fontsize":9})
        else:
            ax1.text(.5,.5,"No data today",ha="center",va="center",
                     color="#6b6b6b",fontsize=12,transform=ax1.transAxes)
        ax1.set_title("Calories by Meal Type",color="#f97316",fontsize=11,pad=10)

        ax2.set_facecolor("#1a1a1a")
        total = df["calories"].sum() if not df.empty else 0
        rem   = max(self.goal-total,0)
        bars  = ax2.bar(["Consumed","Remaining"],[total,rem],
                        color=["#f97316","#22c55e"], width=0.5, edgecolor="none")
        ax2.spines[:].set_color("#2a2a2a"); ax2.tick_params(colors="white")
        ax2.set_ylabel("kcal",color="#6b6b6b",fontsize=9)
        ax2.set_title("Goal Progress",color="#f97316",fontsize=11,pad=10)
        ax2.axhline(self.goal,color="#ef4444",linestyle="--",linewidth=1,
                    label=f"Goal: {self.goal}")
        ax2.legend(fontsize=8,labelcolor="white",framealpha=0)
        for bar in bars:
            h=bar.get_height()
            ax2.text(bar.get_x()+bar.get_width()/2,h+10,f"{h:.0f}",
                     ha="center",va="bottom",color="white",fontsize=9)

        plt.tight_layout(pad=1.5)
        canvas = FigureCanvasTkAgg(fig, master=self.chart_frame)
        canvas.draw(); canvas.get_tk_widget().pack(fill="both",expand=True)
        plt.close(fig)

    def update_week_chart(self):
        for w in self.week_frame.winfo_children(): w.destroy()
        df = self._get_all()
        fig, ax = plt.subplots(figsize=(8,4), facecolor="#1a1a1a")
        ax.set_facecolor("#1a1a1a")
        if not df.empty:
            df["calories"] = pd.to_numeric(df["calories"], errors="coerce")
            daily = df.groupby("date")["calories"].sum().reset_index().tail(7)
            x = np.arange(len(daily))
            bars = ax.bar(x, daily["calories"], color="#f97316",
                          width=0.6, edgecolor="none")
            ax.axhline(self.goal,color="#ef4444",linestyle="--",linewidth=1.5,
                       label=f"Goal: {self.goal} kcal")
            ax.set_xticks(x)
            ax.set_xticklabels([d[-5:] for d in daily["date"]],
                               color="white",fontsize=9)
            ax.tick_params(colors="white"); ax.spines[:].set_color("#2a2a2a")
            ax.set_ylabel("Calories (kcal)",color="#6b6b6b")
            ax.set_title("Last 7 Days",color="#f97316",fontsize=13,pad=12)
            ax.legend(fontsize=9,labelcolor="white",framealpha=0)
            for bar,val in zip(bars,daily["calories"]):
                ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+10,
                        f"{val:.0f}",ha="center",va="bottom",color="white",fontsize=8)
        else:
            ax.text(.5,.5,"No data yet.\nAdd meals to see history!",
                    ha="center",va="center",color="#6b6b6b",fontsize=12,
                    transform=ax.transAxes)
        plt.tight_layout()
        canvas = FigureCanvasTkAgg(fig, master=self.week_frame)
        canvas.draw(); canvas.get_tk_widget().pack(fill="both",expand=True)
        plt.close(fig)

