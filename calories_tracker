        t3 = tk.Frame(nb, bg=self.C["BG"]); nb.add(t3, text="  Weekly  ")

        self._build_log_tab(t1)
        self.chart_frame = tk.Frame(t2, bg=self.C["BG"]); self.chart_frame.pack(fill="both", expand=True)
        self.week_frame  = tk.Frame(t3, bg=self.C["BG"]); self.week_frame.pack(fill="both", expand=True)
